# Supabase — get from project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection for the worker (Supabase → Connect → Session pooler URI).
# Substitute your DB password for [YOUR-PASSWORD]. Used by collectors/engines.
DATABASE_URL=

# GitHub API — personal access token, scope: public_repo
GITHUB_TOKEN=

# LLM
ANTHROPIC_API_KEY=

