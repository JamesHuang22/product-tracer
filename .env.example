# Supabase — get from project settings.
# NEXT_PUBLIC_* are public (safe to ship to the browser); they power auth +
# account-synced bookmarks. Without them the site still runs and bookmarks fall
# back to localStorage (the auth UI shows a "not configured" notice).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of the deployment — used for absolute OG image URLs and the
# email-confirmation redirect (auth/callback). Defaults to the prod URL.
NEXT_PUBLIC_SITE_URL=https://product-tracer.vercel.app

# Direct Postgres connection for the worker (Supabase → Connect → Session pooler URI).
# Substitute your DB password for [YOUR-PASSWORD]. Used by collectors/engines.
DATABASE_URL=

# GitHub API — personal access token, scope: public_repo
GITHUB_TOKEN=

# LLM
ANTHROPIC_API_KEY=

# Email (added in P1)
# RESEND_API_KEY=

# Product Hunt (added in P0)
# PRODUCT_HUNT_DEVELOPER_TOKEN=
